@model IEnumerable<trendaura.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-users fa-2x" style="color: #FFC107;"></i></div>
                    <div>
                        <div class="small" style="color: #cccccc;">Users</div>
                        <div class="h4 mb-0" style="color: #FFC107;">@ViewBag.Users</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-box-open fa-2x" style="color: #FFC107;"></i></div>
                    <div>
                        <div class="small" style="color: #cccccc;">Products</div>
                        <div class="h4 mb-0" style="color: #FFC107;">@ViewBag.Products</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-tags fa-2x" style="color: #FFC107;"></i></div>
                    <div>
                        <div class="small" style="color: #cccccc;">Categories</div>
                        <div class="h4 mb-0" style="color: #FFC107;">@ViewBag.Categories</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="text-decoration-none">
            <div class="admin-card">
                <div class="d-flex align-items-center">
                    <div class="me-3"><i class="fa-solid fa-receipt fa-2x" style="color: #FFC107;"></i></div>
                    <div>
                        <div class="small" style="color: #cccccc;">Orders</div>
                        <div class="h4 mb-0" style="color: #FFC107;">@ViewBag.Orders</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="admin-card">
    <h5 class="mb-3" style="color: #FFC107;">Recent Orders</h5>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="color: #FFC107;">Order #</th>
                    <th style="color: #FFC107;">Customer</th>
                    <th style="color: #FFC107;">Date</th>
                    <th style="color: #FFC107;">Total</th>
                    <th style="color: #FFC107;">Status</th>
                    <th style="color: #FFC107;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td><strong style="color: #cccccc;">@o.Id</strong></td>
                        <td style="color: #cccccc;">@(o.User?.FullName ?? o.User?.Email ?? "N/A")</td>
                        <td style="color: #cccccc;">@o.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td><strong style="color: #FFC107;">Rs @o.TotalAmount.ToString("0.00")</strong></td>
                        <td>
                            <span class="badge" style="background-color: @(o.Status == "Delivered" ? "#4CAF50" : o.Status == "Cancelled" ? "#ff6b6b" : "#FFC107"); color: @(o.Status == "Delivered" || o.Status == "Cancelled" ? "#ffffff" : "#000000");">
                                @o.Status
                            </span>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm" style="background-color: #FFC107; color: #000000; border: none;">
                                View Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
