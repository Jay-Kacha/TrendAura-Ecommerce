@model IEnumerable<trendaura.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 style="color: #FFC107;">Products</h3>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn" style="background-color: #FFC107; color: #000000; border: none;">Add Product</a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="color: #FFC107;">Image</th>
                    <th style="color: #FFC107;">Name</th>
                    <th style="color: #FFC107;">Category</th>
                    <th style="color: #FFC107;">Price</th>
                    <th style="color: #FFC107; width:200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><img src="@(string.IsNullOrEmpty(p.ImageUrl)? "/images/placeholder.png" : p.ImageUrl)" style="height:60px;width:60px;object-fit:cover;border-radius:4px;" alt="@p.Name" /></td>
                        <td style="color: #cccccc;">@p.Name</td>
                        <td style="color: #cccccc;">@p.Category?.Name</td>
                        <td><strong style="color: #FFC107;">Rs @p.Price.ToString("0.00")</strong></td>
                        <td>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm" style="background-color: transparent; border: 2px solid #FFC107; color: #FFC107;">Edit</a>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post" class="d-inline-block">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm" style="background-color: transparent; border: 2px solid #ff6b6b; color: #ff6b6b;" onclick="return confirm('Are you sure you want to delete this product?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
