@model trendaura.ViewModels.AdminReviewsViewModel
@{
    ViewData["Title"] = "Reviews";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 style="color: #FFC107;">Product Reviews</h3>
    <div>
        <span class="badge me-2">Total: @Model.TotalCount</span>
    </div>
</div>

<div class="admin-card mb-3 p-3">
    <form method="get" class="row g-2 align-items-center">
        <div class="col-auto">
            <label class="form-label" style="color:#FFC107;">Filter by product</label>
        </div>
        <div class="col-auto">
            <select name="productId" class="form-select">
                <option value="">All products</option>
                @foreach (var p in Model.Products)
                {
                    if (Model.SelectedProductId == p.Id)
                    {
                        <option value="@p.Id" selected>@p.Name</option>
                    }
                    else
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm" style="background-color: #FFC107; color: #000;">Filter</button>
        </div>
        <div class="col-auto">
            <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        </div>
    </form>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="color: #FFC107;">Product</th>
                    <th style="color: #FFC107;">Reviewer</th>
                    <th style="color: #FFC107;">Rating</th>
                    <th style="color: #FFC107;">Comment</th>
                    <th style="color: #FFC107; width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reviews)
                {
                    <tr>
                        <td style="color: #cccccc;">@r.Product?.Name</td>
                        <td style="color: #cccccc;">
                            @{ 
                                var reviewer = !string.IsNullOrWhiteSpace(r.ReviewerName) ? r.ReviewerName
                                               : !string.IsNullOrWhiteSpace(r.User?.FullName) ? r.User.FullName
                                               : !string.IsNullOrWhiteSpace(r.User?.UserName) ? r.User.UserName
                                               : "Unknown";
                            }
                            @reviewer
                        </td>
                        <td><strong style="color: #FFC107;">@r.Rating</strong></td>
                        <td style="color: #cccccc; max-width:400px; white-space:pre-wrap;">@r.Comment</td>
                        <td>
                            <form asp-area="Admin" asp-controller="Reviews" asp-action="Delete" method="post" class="d-inline-block">
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-sm" style="background-color: transparent; border: 2px solid #ff6b6b; color: #ff6b6b;" onclick="return confirm('Are you sure you want to delete this review?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
