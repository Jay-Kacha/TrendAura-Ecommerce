@model trendaura.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
    /* Full page background */
    .register-page {
        min-height: 100vh;
        background: radial-gradient(circle at top,#111,#000);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI',sans-serif;
    }

    /* Glass card design */
    .register-card {
        width: 100%;
        max-width: 450px;
        padding: 40px;
        border-radius: 18px;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,193,7,0.25);
        box-shadow: 0 15px 45px rgba(0,0,0,0.7);
        color: #fff;
    }

        /* Heading */
        .register-card h3 {
            font-weight: 600;
            color: #FFC107;
        }

        /* Form Controls */
        .register-card .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
        }

            .register-card .form-control::placeholder {
                color: #aaa;
            }

            .register-card .form-control:focus {
                border-color: #FFC107;
                box-shadow: 0 0 10px rgba(255,193,7,0.6);
                background: rgba(255,255,255,0.12);
            }

    /* Button */
    .btn-register {
        background: #FFC107;
        border: none;
        color: #000;
        font-weight: 600;
        transition: .3s;
        padding: 12px;
    }

        .btn-register:hover {
            background: #ffd54f;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,193,7,0.3);
        }

    /* Links */
    .register-card a {
        color: #FFC107;
        text-decoration: none;
    }

        .register-card a:hover {
            text-decoration: underline;
        }

    /* Validation Styles */
    .validation-summary-errors ul {
        list-style: none;
        padding-left: 0;
    }
</style>

<div class="register-page">
    <div class="register-card">
        <div class="text-center mb-4">
            <h3>Create Account</h3>
            <p class="text-secondary">Join TrendAura today</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">

            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Dhruv Moliya" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="dhruv@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-register w-100 mb-3">
                Register Now
            </button>

            <div class="text-center">
                <p class="mb-0">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login">Login here</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}