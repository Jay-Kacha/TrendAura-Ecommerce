@model trendaura.ViewModels.ProductReviewsViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<div class="container my-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active">@Model.Product.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-5 mb-4">
            <div class="product-card shadow-sm border rounded p-2 bg-white">
                <img src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? "/images/placeholder.png" : Model.Product.ImageUrl)"
                     alt="@Model.Product.Name" class="img-fluid rounded" style="width:100%;max-height:500px;object-fit:cover;" />
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-md-7">
            <div class="p-4 shadow-sm border rounded bg-white">
                <h2 class="mb-2">@Model.Product.Name</h2>

                @if (Model.Product.Category != null)
                {
                    <p class="text-muted mb-3">
                        <i class="fa-solid fa-tag me-2"></i>
                        <a asp-controller="Home" asp-action="Category" asp-route-id="@Model.Product.CategoryId">@Model.Product.Category.Name</a>
                    </p>
                }

                <div class="d-flex align-items-center mb-3">
                    <div class="text-warning me-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="@(i <= Model.Product.AverageRating ? "fa-solid" : "fa-regular") fa-star"></i>
                        }
                    </div>
                    <span class="text-muted small">(@Model.Product.ReviewCount Reviews)</span>
                </div>

                <h3 class="price mb-4 text-primary">Rs @Model.Product.Price.ToString("0.00")</h3>

                <div class="mb-4">
                    <h6 class="fw-bold">Description</h6>
                    <p class="text-dark small">@Model.Product.Description</p>
                </div>

                <!-- Add to Cart Form -->
                <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                    <input type="hidden" name="productId" value="@Model.Product.Id" />
                    <div class="row align-items-end g-2">
                        <div class="col-auto">
                            <label class="form-label small fw-bold">Quantity</label>
                            <input type="number" name="quantity" value="1" min="1" max="99" class="form-control" style="width:80px;" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fa-solid fa-cart-plus me-2"></i>Add to Cart
                            </button>
                        </div>
                    </div>
                </form>

                <div class="d-flex gap-2">
                    <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                        <input type="hidden" name="productId" value="@Model.Product.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="fa-regular fa-heart me-2"></i>Wishlist
                        </button>
                    </form>

                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Reviews Section -->
    <div class="row">
        <div class="col-md-12">
            <h4 class="mb-4">Customer Reviews</h4>

            @if (User.Identity!.IsAuthenticated)
            {
                <div class="card mb-4 shadow-sm border-warning">
                    <div class="card-body">
                        <h6 class="fw-bold">Write a Review</h6>
                        <form asp-controller="Review" asp-action="Add" method="post">
                            @* 
                                FIXED: Yahan asp-for use nahi karenge kyunki wo 
                                background mein purane model ki property dhoondh raha hai.
                                Manual 'name' use karne se CS1061 error chali jayegi.
                            *@
                            <input type="hidden" name="NewReview.AccessoryId" value="@Model.Product.Id" />

                            <div class="mb-3">
                                <label class="form-label small">Rating</label>
                                <select name="NewReview.Rating" class="form-select w-auto">
                                    <option value="5">5 - Excellent</option>
                                    <option value="4">4 - Very Good</option>
                                    <option value="3" selected>3 - Good</option>
                                    <option value="2">2 - Fair</option>
                                    <option value="1">1 - Poor</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small">Comment</label>
                                <textarea name="NewReview.Comment" class="form-control" rows="3" placeholder="Share your experience..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning">Submit Review</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-secondary py-2">
                    <small>Please <a asp-controller="Account" asp-action="Login" class="fw-bold">Login</a> to write a review.</small>
                </div>
            }

            <!-- Display Reviews List -->
            <div class="review-list">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="border-bottom mb-3 pb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-0 fw-bold">@review.ReviewerName</h6>
                                    <div class="text-warning x-small mb-1">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="@(i <= review.Rating ? "fa-solid" : "fa-regular") fa-star" style="font-size: 0.8rem;"></i>
                                        }
                                        @if (review.IsVerifiedPurchase)
                                        {
                                            <span class="badge bg-light text-success border ms-2" style="font-size:0.6rem;">Verified Purchase</span>
                                        }
                                    </div>
                                </div>
                                <small class="text-muted" style="font-size: 0.75rem;">@review.CreatedAt.ToString("dd MMM yyyy")</small>
                            </div>
                            <p class="mb-0 text-muted small">@review.Comment</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small italic">No reviews yet. Be the first to review this product!</p>
                }
            </div>
        </div>
    </div>
</div>